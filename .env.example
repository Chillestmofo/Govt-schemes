# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Vector Database Configuration
CHROMA_PERSIST_DIRECTORY=./data/chroma_db

# RAG Configuration
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4-turbo-preview
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RESULTS=5

# Application Configuration
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=True

# MyScheme Website
MYSCHEME_BASE_URL=https://www.myscheme.gov.in
MYSCHEME_API_KEY=your_myscheme_api_key_here

# macOS OpenMP Fix (Required for some environments)
KMP_DUPLICATE_LIB_OK=TRUE

# Optional: Notification SMTP (for alert emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SENDER=

# Optional: automated alert dispatcher
AUTO_ALERT_DISPATCH_ENABLED=0
AUTO_ALERT_DISPATCH_INTERVAL_MIN=60
ADMIN_DISPATCH_TOKEN=

# Worker / Redis
REDIS_URL=redis://127.0.0.1:6379/0
RQ_QUEUE_NAME=scheme_tasks
WORKER_MAX_RETRIES=3
WORKER_SYNC_FALLBACK=0

# Push notifications
FCM_SERVER_KEY=
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIMS_SUB=mailto:admin@example.com

# External status polling
SCHEME_STATUS_API_BASE=
